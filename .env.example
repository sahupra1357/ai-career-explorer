# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Phase 2: OpenAI embeddings (text-embedding-3-small). Get at https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ── Local development flags ────────────────────────────────────────────────────
# Set MOCK_CLAUDE=1 to skip real Claude calls during frontend development.
# generate_summary() returns a static string. Costs $0. Responds instantly.
MOCK_CLAUDE=1

# Set DEBUG_PROMPTS=1 to write the full Claude prompt to logs/prompts/{request_id}.txt
# before each API call. Useful when comparison_summary looks wrong.
DEBUG_PROMPTS=0

# Phase 2: set MOCK_EMBEDDINGS=1 to stub OpenAI embed + pgvector. No Docker needed.
# embed_text() returns a zero vector; search returns a random KB sample.
MOCK_EMBEDDINGS=1

# Course finder behavior:
# agent (default) = LangGraph multi-agent workflow — the KG seeds the finite candidate
#                   colleges, then one tool-using subagent per college investigates its
#                   official program page live, in parallel. See AGENT_* + KG_BACKEND below.
# kg       = serve straight from the pre-built knowledge graph (instant, no agents).
# live     = live official .edu discovery only (no curated fallback).
# fallback = use data/college_programs.yaml as curated local data.
COURSE_SEARCH_MODE=agent
# Agent workflow tuning (COURSE_SEARCH_MODE=agent):
AGENT_CONCURRENCY=3      # how many college subagents run at once (keep low on low API tiers)
AGENT_MAX_ROUNDS=4       # max search/fetch tool rounds per subagent
# LLM provider for the subagents: openai (default) or anthropic.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini          # subagent model when LLM_PROVIDER=openai
# AGENT_MODEL=claude-sonnet-4-6   # subagent model when LLM_PROVIDER=anthropic (else CLAUDE_MODEL)

# Knowledge-graph backend (COURSE_SEARCH_MODE=kg):
#   sample (default) — in-memory from data/scorecard_sample.json, no DB needed.
#   postgres         — query kg_* tables (run `make build-kg` first; needs DATABASE_URL).
KG_BACKEND=sample
# Free key for the live Scorecard ETL (api.data.gov); only needed for `make build-kg ARGS=--source api`.
SCORECARD_API_KEY=

# Rankings:
#  - ranking_score is always a transparent composite from open Scorecard outcomes.
#  - Carnegie Classification (free) is shown when loaded via `make load-carnegie`.
#  - LICENSED provider ranks (e.g. U.S. News) are served ONLY when this is 1. Default off:
#    do not enable unless you hold a data licence and loaded rows via `make load-rankings`.
RANKINGS_LICENSED=0

# Page reading / KG enrichment: when 1, after ranking the app reads the official program
# page for ONLY the colleges shown (pinpoint search per college+course → fetch → extract),
# in parallel, filling the curriculum gap on demand. Honors MOCK_CLAUDE=1.
#   NOTE: Claude web_search is input-token-heavy — on a low Anthropic tier (e.g. 30K
#   tokens/min) even a few concurrent calls hit 429. For enrichment, prefer a dedicated
#   search API for discovery (SEARCH_PROVIDER=brave|tavily — no Anthropic tokens), keeping
#   Claude for extraction only; and keep KG_ENRICH_CONCURRENCY low.
COURSE_READ_PAGES=0
KG_ENRICH_CONCURRENCY=3
# Per college: how many candidate program pages to try (multi-candidate pinpoint search)
# until one yields a real course grid. Higher = better coverage, more cost/latency.
KG_MAX_CANDIDATES=3

# Discovery search provider (how live mode + KG enrichment find official .edu pages):
#   tavily (default) — Tavily Search API  (set TAVILY_API_KEY; free tier ~1k credits/mo)
#   brave            — Brave Search API   (set BRAVE_API_KEY;  free tier ~2k queries/mo)
#   apify            — Apify search Actor  (set APIFY_TOKEN; Google-grade, heavier/slower)
#   claude           — Anthropic web_search server tool (token-heavy; 429s on low tiers)
#   duckduckgo       — free HTML scrape, no key, but rate-limited/blocked often
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=
# Apify (SEARCH_PROVIDER=apify): default actor is Google Search Scraper.
APIFY_TOKEN=
APIFY_ACTOR=apify~google-search-scraper
# Claude web_search tuning (only used when SEARCH_PROVIDER=claude):
# web_search_20250305 returns plain url/title result items (recommended).
# web_search_20260209 adds code-execution dynamic filtering but hides those fields.
CLAUDE_WEBSEARCH_TOOL=web_search_20250305
CLAUDE_WEBSEARCH_MAX_USES=3
CLAUDE_WEBSEARCH_TIMEOUT_S=90

# ── App settings ──────────────────────────────────────────────────────────────
FIELDS_FILE=data/fields.yaml
LOG_LEVEL=INFO

# ── Phase 2: Database ─────────────────────────────────────────────────────────
# Start Postgres: docker compose up -d
# Run migrations: make migrate
# Seed embeddings: make embed
DATABASE_URL=postgresql://dev:dev@localhost:5433/career_explorer
