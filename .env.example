# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Phase 2: OpenAI embeddings (text-embedding-3-small). Get at https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ── Local development flags ────────────────────────────────────────────────────
# Set MOCK_CLAUDE=1 to skip real Claude calls during frontend development.
# generate_summary() returns a static string. Costs $0. Responds instantly.
MOCK_CLAUDE=1

# Set DEBUG_PROMPTS=1 to write the full Claude prompt to logs/prompts/{request_id}.txt
# before each API call. Useful when comparison_summary looks wrong.
DEBUG_PROMPTS=0

# Phase 2: set MOCK_EMBEDDINGS=1 to stub OpenAI embed + pgvector. No Docker needed.
# embed_text() returns a zero vector; search returns a random KB sample.
MOCK_EMBEDDINGS=1

# ── App settings ──────────────────────────────────────────────────────────────
FIELDS_FILE=data/fields.yaml
LOG_LEVEL=INFO

# ── Phase 2: Database ─────────────────────────────────────────────────────────
# Start Postgres: docker compose up -d
# Run migrations: make migrate
# Seed embeddings: make embed
DATABASE_URL=postgresql://dev:dev@localhost:5433/career_explorer
