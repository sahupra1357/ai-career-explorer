# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ── Local development flags ────────────────────────────────────────────────────
# Set MOCK_CLAUDE=1 to skip real Claude calls during frontend development.
# generate_summary() returns a static string. Costs $0. Responds instantly.
MOCK_CLAUDE=1

# Set DEBUG_PROMPTS=1 to write the full Claude prompt to logs/prompts/{request_id}.txt
# before each API call. Useful when comparison_summary looks wrong.
DEBUG_PROMPTS=0

# ── App settings ──────────────────────────────────────────────────────────────
FIELDS_FILE=data/fields.yaml
LOG_LEVEL=INFO
